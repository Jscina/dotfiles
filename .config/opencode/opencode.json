{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "jscina/Qwen3-Coder-30B-A3B-Instruct:latest": {
          "name": "Qwen3-Coder-30B-A3B-Instruct",
          "tool_call": true
        }
      }
    }
  },
  "mcp": {
    "copeland-code-search": {
      "type": "remote",
      "url": "https://copeland-cortex-dev-mcp.azurewebsites.net/mcp",
      "enabled": true
    },
    "lazytail": {
      "type": "local",
      "command": ["lazytail", "--mcp"]
    }
  }
}
