{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@ex-machina/opencode-anthropic-auth@1.8.0",
    "opencode-gemini-auth@1.4.15",
    "/home/joshs/.openagent-harness/harness.ts"
  ],
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_MCP_TOKEN}"
      }
    },
    "websearch": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp"
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "grep_app": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    }
  },
  "provider": {
    "ollama": {
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3-coder-builder:latest": {
          "tool_call": true,
          "name": "qwen3-coder-builder:latest"
        },
        "qwen3-coder-junior:latest": {
          "tool_call": true,
          "name": "qwen3-coder-junior:latest"
        },
        "qwen3-docs:latest": {
          "reasoning": true,
          "tool_call": true,
          "name": "qwen3-docs:latest"
        },
        "qwen2.5-vl-vision:latest": {
          "tool_call": false,
          "name": "qwen2.5-vl-vision:latest"
        }
      }
    }
  },
  "permission": {
    "bash": {
      "*": "allow",
      "rm *": "ask",
      "rm -rf *": "deny",
      "sudo *": "ask",
      "npm publish *": "deny",
      "git push *": "deny"
    },
    "edit": "ask",
    "task": "allow",
    "doom_loop": "ask"
  },
  "agent": {
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    },
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "scout": {
      "disable": true
    },
    "summary": {
      "disable": true
    }
  }
}
