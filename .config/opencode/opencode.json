{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-gemini-auth@latest",
    "opencode-claude-auth@latest",
    "/home/joshs/.openagent-harness/harness.ts"
  ],
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_MCP_TOKEN}"
      }
    },
    "websearch": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp"
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "grep_app": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    }
  },
  "provider": {
    "ollama": {
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3-coder:30b": {
          "reasoning": true,
          "tool_call": true,
          "name": "qwen3-coder:30b",
          "options": {
            "num_ctx": 65535
          }
        }
      }
    }
  },
  "permission": {
    "skill": {
      "code-review": "allow",
      "git-rebase-fixup": "allow"
    }
  },
  "agent": {
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    },
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "summary": {
      "disable": true
    },
    "explorer": {
      "fallback_models": [
        "ollama/qwen3-coder",
        "anthropic/claude-haiku-4-5"
      ]
    },
    "builder-junior": {
      "fallback_models": [
        "ollama/qwen3-coder",
        "anthropic/claude-haiku-4-5"
      ]
    }
  }
}
