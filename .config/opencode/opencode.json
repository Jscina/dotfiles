{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-gemini-auth@latest",
    "@ex-machina/opencode-anthropic-auth",
    "/Users/jscina/.openagent-harness/harness.ts"
  ],
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_MCP_TOKEN}"
      }
    },
    "azure": {
      "type": "local",
      "command": ["npx", "-y", "@azure/mcp@latest", "server", "start"]
    },
    "ado": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@azure-devops/mcp@next",
        "{env:ADO_ORG}",
        "--authentication",
        "envvar"
      ]
    },
    "copeland-code-search": {
      "type": "remote",
      "url": "https://copeland-cortex-dev-mcp.azurewebsites.net/mcp",
      "enabled": true
    },

    "websearch": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp"
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "grep_app": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    }
  },
  "provider": {
    "ollama": {
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3-coder:30b": {
          "tool_call": true,
          "name": "qwen3-coder:30b"
        },
        "qwen3.5:9b": {
          "reasoning": true,
          "tool_call": true,
          "name": "qwen3.5:9b"
        },
        "llama3.1:8b": {
          "tool_call": true,
          "name": "llama3.1:8b"
        }
      }
    }
  },
  "permission": {
    "skill": {
      "azure-readonly": "allow",
      "azure-deploy": "ask",
      "bicep-iac": "allow",
      "code-review": "allow",
      "copeland-code-search": "deny",
      "git-rebase-fixup": "allow",
      "pr-workflow": "allow",
      "debug": "allow"
    }
  },
  "agent": {
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    }
  }
}
