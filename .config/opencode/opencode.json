{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-gemini-auth@latest",
    "@ex-machina/opencode-anthropic-auth",
    "oh-my-openagent@latest"
  ],
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_MCP_TOKEN}"
      }
    },
    "azure": {
      "type": "local",
      "command": ["npx", "-y", "@azure/mcp@latest", "server", "start"]
    },
    "ado": {
      "type": "local",
      "command": ["npx", "-y", "@azure-devops/mcp@next", "${env:ADO_ORG}"]
    },
    "copeland-code-search": {
      "type": "remote",
      "url": "https://copeland-cortex-dev-mcp.azurewebsites.net/mcp",
      "enabled": true,
      "oauth": false
    },
    "lazytail": {
      "command": ["lazytail", "--mcp"],
      "type": "local"
    }
  },
  "provider": {
    "ollama": {
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3.5": {
          "reasoning": true,
          "tool_call": true,
          "name": "qwen3.5"
        }
      }
    },
    "google": {
      "options": {
        "projectId": "gemini-cli-491423"
      }
    }
  },
  "permission": {
    "skill": {
      "azure-readonly": "allow",
      "git-rebase-fixup": "allow"
    },
    "bash": {
      "az *": "ask",
      "git push": "deny",
      "git log --oneline -n 10": "allow"
    }
  }
}
