{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-gemini-auth@latest",
    "@ex-machina/opencode-anthropic-auth",
    "oh-my-openagent@latest"
  ],
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_MCP_TOKEN}"
      }
    },
    "azure": {
      "type": "local",
      "command": ["npx", "-y", "@azure/mcp@latest", "server", "start"]
    },
    "ado": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@azure-devops/mcp@next",
        "{env:ADO_ORG}",
        "--authentication",
        "envvar"
      ]
    },
    "copeland-code-search": {
      "type": "remote",
      "url": "https://copeland-cortex-dev-mcp.azurewebsites.net/mcp",
      "enabled": true
    },
    "lazytail": {
      "command": ["lazytail", "--mcp"],
      "type": "local",
      "enabled": false
    }
  },
  "provider": {
    "ollama": {
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "omo-explore": {
          "tool_call": true,
          "name": "omo-explore"
        },
        "omo-librarian": {
          "tool_call": true,
          "name": "omo-librarian"
        },
        "omo-quick": {
          "tool_call": true,
          "name": "omo-quick"
        }
      }
    }
  },
  "permission": {
    "skill": {
      "azure-readonly": "allow",
      "azure-deploy": "ask",
      "bicep-iac": "allow",
      "code-review": "allow",
      "copeland-code-search": "deny",
      "git-rebase-fixup": "allow",
      "pr-workflow": "allow",
      "debug": "allow"
    }
  }
}
