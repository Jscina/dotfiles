{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "main_pane_size": 60,
    "main_pane_min_width": 120,
    "agent_pane_min_width": 40,
    "isolation": "window"
  },
  "git_master": {
    "commit_footer": true,
    "include_co_authored_by": true,
    "git_env_prefix": "GIT_MASTER=1"
  },
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [400, 429, 503, 529],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 60,
    "timeout_seconds": 30,
    "notify_on_fallback": true
  },
  "agents": {
    "sisyphus": {
      "model": "anthropic/claude-sonnet-4-6",
      "variant": "max",
      "fallback_models": [
        { "model": "opencode/big-pickle" },
        { "model": "openai/gpt-5.4", "variant": "medium" }
      ],
      "skills": [".opencode/skills/git-rebase-fixup/SKILL.md"]
    },
    "hephaestus": {
      "model": "google/gemini-3.1-pro-preview",
      "variant": "high",
      "fallback_models": [
        { "model": "anthropic/claude-sonnet-4-6" },
        { "model": "openai/gpt-5.4", "variant": "medium" }
      ],
      "skills": [".opencode/skills/git-rebase-fixup/SKILL.md"]
    },
    "oracle": {
      "model": "google/gemini-3.1-pro-preview",
      "variant": "high",
      "fallback_models": [
        { "model": "anthropic/claude-opus-4-6", "variant": "max" },
        { "model": "openai/gpt-5.4", "variant": "high" }
      ],
      "skills": [
        ".opencode/skills/code-review/SKILL.md",
        ".opencode/skills/debug/SKILL.md"
      ]
    },
    "explore": {
      "model": "ollama/qwen3-coder"
    },
    "librarian": {
      "model": "ollama/qwen3-coder"
    },
    "multimodal-looker": {
      "model": "google/gemini-2.5-flash",
      "fallback_models": [{ "model": "openai/gpt-5.4", "variant": "medium" }]
    },
    "prometheus": {
      "model": "anthropic/claude-sonnet-4-6",
      "variant": "max",
      "fallback_models": [
        { "model": "openai/gpt-5.4", "variant": "high" },
        { "model": "google/gemini-3.1-pro-preview" }
      ]
    },
    "metis": {
      "model": "anthropic/claude-sonnet-4-6",
      "variant": "max",
      "fallback_models": [{ "model": "openai/gpt-5.4", "variant": "high" }]
    },
    "momus": {
      "model": "anthropic/claude-opus-4-6",
      "variant": "max",
      "fallback_models": [
        { "model": "google/gemini-3.1-pro-preview", "variant": "high" },
        { "model": "openai/gpt-5.4", "variant": "xhigh" }
      ],
      "skills": [".opencode/skills/code-review/SKILL.md"]
    },
    "atlas": {
      "model": "anthropic/claude-sonnet-4-6",
      "fallback_models": [
        { "model": "openai/gpt-5.4", "variant": "medium" },
        { "model": "ollama/qwen3-coder" }
      ],
      "skills": [".opencode/skills/git-rebase-fixup/SKILL.md"]
    },
    "sisyphus-junior": {
      "model": "anthropic/claude-sonnet-4-6",
      "fallback_models": [
        { "model": "openai/gpt-5.4", "variant": "medium" },
        { "model": "ollama/qwen3-coder" }
      ],
      "skills": [".opencode/skills/git-rebase-fixup/SKILL.md"]
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "google/gemini-3.1-pro-preview",
      "variant": "high",
      "fallback_models": [
        { "model": "anthropic/claude-opus-4-6", "variant": "max" }
      ]
    },
    "ultrabrain": {
      "model": "google/gemini-3.1-pro-preview",
      "variant": "high",
      "fallback_models": [
        { "model": "openai/gpt-5.4", "variant": "xhigh" },
        { "model": "anthropic/claude-opus-4-6", "variant": "max" }
      ]
    },
    "artistry": {
      "model": "google/gemini-3.1-pro-preview",
      "variant": "high",
      "fallback_models": [
        { "model": "anthropic/claude-opus-4-6", "variant": "max" },
        { "model": "openai/gpt-5.4" }
      ]
    },
    "quick": {
      "model": "ollama/qwen3-coder",
      "fallback_models": [{ "model": "opencode/gpt-5-nano" }]
    },
    "unspecified-low": {
      "model": "anthropic/claude-sonnet-4-6",
      "fallback_models": [
        { "model": "openai/gpt-5.3-codex", "variant": "medium" },
        { "model": "google/gemini-3-flash-preview" }
      ]
    },
    "unspecified-high": {
      "model": "anthropic/claude-sonnet-4-6",
      "fallback_models": [{ "model": "openai/gpt-5.4", "variant": "high" }]
    },
    "writing": {
      "model": "opencode/qwen3.6-plus-free",
      "fallback_models": [
        {
          "model": "google/gemini-3-flash-preview"
        }
      ]
    }
  }
}
