      "fallback_models": [
        { "model": "google/gemini-3.1-pro-preview" },
        { "model": "opencode/nemotron-3-super-free" }
      ],
      "skills": [".opencode/skills/code-review/SKILL.md"]
    },
    "atlas": {
      "model": "anthropic/claude-sonnet-4-6",
      "fallback_models": [
        { "model": "google/gemini-3.1-pro-preview" },
        { "model": "opencode/mimo-v2-pro-free" }
      ],
      "skills": [
        ".opencode/skills/git-rebase-fixup/SKILL.md",
        ".opencode/skills/copeland-code-search/SKILL.md"
      ]
    },
    "sisyphus-junior": {
      "model": "anthropic/claude-sonnet-4-6",
      "fallback_models": [
        { "model": "google/gemini-3.1-pro-preview" },
        { "model": "opencode/mimo-v2-pro-free" }
      ],
      "skills": [
        ".opencode/skills/git-rebase-fixup/SKILL.md",
        ".opencode/skills/copeland-code-search/SKILL.md"
      ]
    }
  },
  "categories": {
    "visual-engineering": {
