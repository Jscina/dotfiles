{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "main_pane_size": 60,
    "main_pane_min_width": 120,
    "agent_pane_min_width": 40,
    "isolation": "window"
  },
  "git_master": {
    "commit_footer": true,
    "include_co_authored_by": true,
    "git_env_prefix": "GIT_MASTER=1"
  },
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [400, 429, 503, 529],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 60,
    "timeout_seconds": 30,
    "notify_on_fallback": true
  },
  "agents": {
    "sisyphus": {
      "model": "anthropic/claude-sonnet-4-6",
      "variant": "max",
      "fallback_models": [
        { "model": "google/gemini-3.1-pro-preview" },
        { "model": "opencode/big-pickle" }
      ],
      "skills": [
        ".opencode/skills/git-rebase-fixup/SKILL.md",
        ".opencode/skills/copeland-code-search/SKILL.md",
        ".opencode/skills/pr-workflow/SKILL.md"
      ]
    },
    "hephaestus": {
      "model": "google/gemini-3.1-pro-preview",
      "variant": "high",
      "fallback_models": [
        { "model": "anthropic/claude-sonnet-4-6" },
        { "model": "opencode/big-pickle" }
      ],
      "skills": [
        ".opencode/skills/azure-deploy/SKILL.md",
        ".opencode/skills/bicep-iac/SKILL.md",
        ".opencode/skills/git-rebase-fixup/SKILL.md"
      ]
    },
    "oracle": {
      "model": "google/gemini-3.1-pro-preview",
      "variant": "high",
      "fallback_models": [
        { "model": "anthropic/claude-sonnet-4-6" },
        { "model": "opencode/nemotron-3-super-free" }
      ],
      "skills": [
        ".opencode/skills/azure-readonly/SKILL.md",
        ".opencode/skills/code-review/SKILL.md",
        ".opencode/skills/debug/SKILL.md"
      ]
    },
    "explore": {
      "model": "anthropic/claude-haiku-4-5",
      "fallback_models": [
        { "model": "google/gemini-3.1-flash-lite-preview" },
        { "model": "ollama/qwen3.5" }
      ],
      "skills": [".opencode/skills/copeland-code-search/SKILL.md"]
    },
    "multimodal-looker": {
      "model": "google/gemini-2.5-flash",
      "fallback_models": [
        { "model": "anthropic/claude-3-5-sonnet-latest" },
        { "model": "opencode/mimo-v2-omni-free" }
      ]
    },
    "prometheus": {
      "model": "anthropic/claude-sonnet-4-6",
      "variant": "max",
      "fallback_models": [
        { "model": "google/gemini-3.1-pro-preview" },
        { "model": "opencode/big-pickle" }
      ],
      "skills": [
        ".opencode/skills/copeland-code-search/SKILL.md",
        ".opencode/skills/azure-readonly/SKILL.md"
      ]
    },
    "metis": {
      "model": "anthropic/claude-sonnet-4-6",
      "variant": "max",
      "fallback_models": [
        { "model": "google/gemini-3.1-pro-preview" },
        { "model": "opencode/minimax-m2.5-free" }
      ]
    },
    "momus": {
      "model": "anthropic/claude-opus-4-6",
