{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "main_pane_size": 60,
    "main_pane_min_width": 120,
    "agent_pane_min_width": 40,
    "isolation": "window"
  },
  "git_master": {
    "commit_footer": true,
    "include_co_authored_by": true,
    "git_env_prefix": "GIT_MASTER=1"
  },
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [400, 429, 503, 529],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 60,
    "timeout_seconds": 30,
    "notify_on_fallback": true
  },
  "background_task": {
    "providerConcurrency": {
      "anthropic": 3
    }
  },
  "agents": {
    "sisyphus": {
      "model": "anthropic/claude-sonnet-4-6",
      "variant": "max",
      "prompt": "file://~/.config/opencode/prompt/sisyphus.md",
      "fallback_models": [
        {
          "model": "opencode/big-pickle"
        }
      ]
    },
    "hephaestus": {
      "model": "openai/gpt-5.4",
      "variant": "medium",
      "prompt": "file://~/.config/opencode/prompt/hephaestus.md",
      "skills": [
        ".opencode/skills/debug/SKILL.md",
        ".opencode/skills/git-rebase-fixup/SKILL.md"
      ]
    },
    "oracle": {
      "model": "openai/gpt-5.4",
      "variant": "high",
      "prompt": "file://~/.config/opencode/prompt/oracle.md",
      "fallback_models": [
        {
          "model": "google/gemini-3.1-pro-preview",
          "variant": "high"
        }
      ],
      "skills": [
        ".opencode/skills/code-review/SKILL.md",
        ".opencode/skills/debug/SKILL.md"
      ]
    },
    "explore": {
      "model": "opencode/minimax-m2.5-free",
      "prompt": "file://~/.config/opencode/prompt/explore.md"
    },
    "librarian": {
      "model": "opencode/gpt-5-nano",
      "prompt": "file://~/.config/opencode/prompt/librarian.md"
    },
    "multimodal-looker": {
      "model": "openai/gpt-5.4",
      "variant": "medium",
      "prompt": "file://~/.config/opencode/prompt/multimodal-looker.md",
      "fallback_models": [
        {
          "model": "google/gemini-2.5-flash"
        }
      ]
    },
    "prometheus": {
      "prompt": "file://~/.config/opencode/prompt/prometheus.md",
      "fallback_models": [
        {
          "model": "google/gemini-3.1-pro-preview"
        }
      ]
    },
    "metis": {
      "model": "openai/gpt-5.4",
      "variant": "high",
      "prompt": "file://~/.config/opencode/prompt/metis.md",
      "fallback_models": [
        {
          "model": "anthropic/claude-sonnet-4-6",
          "variant": "max"
        }
      ]
    },
    "momus": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "prompt": "file://~/.config/opencode/prompt/momus.md",
      "fallback_models": [
        {
          "model": "google/gemini-3.1-pro-preview",
          "variant": "high"
        }
      ],
      "skills": [".opencode/skills/code-review/SKILL.md"]
    },
    "atlas": {
      "model": "google/gemini-3.1-pro-preview",
      "prompt": "file://~/.config/opencode/prompt/atlas.md",
      "fallback_models": [
        {
          "model": "openai/gpt-5.4",
          "variant": "medium"
        }
      ],
      "skills": [".opencode/skills/git-rebase-fixup/SKILL.md"]
    },
    "sisyphus-junior": {
      "model": "anthropic/claude-sonnet-4-6",
      "prompt": "file://~/.config/opencode/prompt/sisyphus-junior.md",
      "fallback_models": [
        {
          "model": "opencode/big-pickle"
        }
      ],
      "skills": [".opencode/skills/git-rebase-fixup/SKILL.md"]
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "google/gemini-3.1-pro-preview",
      "variant": "high",
      "fallback_models": [
        {
          "model": "openai/gpt-5.4",
          "variant": "xhigh"
        }
      ]
    },
    "ultrabrain": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        {
          "model": "google/gemini-3.1-pro-preview",
          "variant": "high"
        }
      ]
    },
    "artistry": {
      "model": "google/gemini-3.1-pro-preview",
      "variant": "high",
      "fallback_models": [
        {
          "model": "openai/gpt-5.4",
          "variant": "xhigh"
        }
      ]
    },
    "quick": {
      "model": "ollama/omo-quick"
    },
    "unspecified-low": {
      "model": "anthropic/claude-sonnet-4-6",
      "fallback_models": [
        {
          "model": "google/gemini-3-flash-preview"
        }
      ]
    },
    "unspecified-high": {
      "model": "openai/gpt-5.4",
      "variant": "high",
      "fallback_models": [
        {
          "model": "anthropic/claude-sonnet-4-6"
        }
      ]
    },
    "writing": {
      "model": "google/gemini-3-flash-preview",
      "fallback_models": [
        {
          "model": "ollama/omo-quick"
        }
      ]
    }
  }
}
